{
  "entities": {
    "User": {
      "title": "User Profile and Game Stats",
      "description": "Represents a user's game state, currency, completed levels, and missions.",
      "type": "object",
      "properties": {
        "xp": { "type": "integer", "description": "Current experience points in the current level" },
        "level": { "type": "integer", "description": "Current level of the user" },
        "hearts": { "type": "integer", "description": "Current life/hearts count" },
        "maxHearts": { "type": "integer", "description": "Maximum life/hearts count" },
        "coins": { "type": "integer", "description": "Current coin balance" },
        "streak": { "type": "integer", "description": "Current daily streak count" },
        "lastActiveDate": { "type": "string", "description": "Last active timestamp in ISO-8601 format" },
        "completedLessons": { "type": "array", "description": "List of completed lesson IDs" },
        "unlockedAchievements": { "type": "array", "description": "List of unlocked achievement IDs" },
        "activeTrack": { "type": "string", "enum": ["html", "css", "js"], "description": "Currently active learning track" },
        "dailyMissions": { "type": "array", "description": "List of active daily missions" },
        "userToken": { "type": "string", "description": "Unique access token for automatic cloud saving" }
      },
      "required": ["xp", "level", "hearts", "maxHearts", "coins", "streak", "lastActiveDate", "completedLessons", "unlockedAchievements", "activeTrack", "dailyMissions", "userToken"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Store individual player game progression and stats."
    }
  }
}
